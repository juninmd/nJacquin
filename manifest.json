{
	"manifest_version": 3,
	"name": "nJacquin",
	"version": "1.0",
	"description": "Coloque um 'tompero' no seu navegador.",
	"icons": {
    	"48": "icon48.png",
        "128": "icon128.png"
    },
	"content_scripts": [
	    {
	      "matches": ["*://*/*"],
	      "js": ["jquery.js", "nJacquin.js"]
	    }
	],
	"web_accessible_resources": [
    {
      "resources": ["images/*.jpg", "images/*.png"],
      "matches": ["<all_urls>"]
    }
	]
}
